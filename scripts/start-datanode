#!/usr/bin/env bash
set -euo pipefail

NODE_ID=$1
RPC_ADDR=$2
HTTP_ADDR=$3

GREPTIME_BIN="${GREPTIME_BIN:-./greptime}"
GREPTIME_HOME="${GREPTIME_HOME:-./.greptimedb}"
METASRV_ADDR="${METASRV_ADDR:-127.0.0.1:3002}"
DATA_DIR="${GREPTIME_HOME}/data-${NODE_ID}"
CONFIG="${DATA_DIR}/datanode.toml"

source "${GREPTIME_HOME}/s3.env"

mkdir -p "${DATA_DIR}"

cat > "${CONFIG}" <<EOF
[storage]
data_home = "${DATA_DIR}"
type = "S3"
bucket = "${S3_BUCKET}"
root = "data"
endpoint = "${S3_ENDPOINT_URL}"
region = "${S3_REGION}"
access_key_id = "${S3_ACCESS_KEY}"
secret_access_key = "${S3_SECRET_KEY}"

[wal]
provider = "raft_engine"
dir = "${DATA_DIR}/wal"

[logging]
dir = "${DATA_DIR}/logs"
EOF

exec ${GREPTIME_BIN} datanode start \
  --node-id "${NODE_ID}" \
  --grpc-bind-addr "${RPC_ADDR}" \
  --http-addr "${HTTP_ADDR}" \
  --metasrv-addrs "${METASRV_ADDR}" \
  --config-file "${CONFIG}"
