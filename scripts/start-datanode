#!/usr/bin/env bash
set -euo pipefail

NODE_ID=$1
RPC_ADDR=$2
HTTP_ADDR=$3

GREPTIME_BIN="${GREPTIME_BIN:-./greptime}"
GREPTIME_HOME="${GREPTIME_HOME:-./.greptimedb}"
METASRV_ADDR="${METASRV_ADDR:-127.0.0.1:3002}"
DATA_DIR="${GREPTIME_HOME}/data-${NODE_ID}"
CONFIG_TEMPLATE="$(dirname "$0")/../config/datanode.toml"
CONFIG="${DATA_DIR}/datanode.toml"

source "${GREPTIME_HOME}/s3.env"

mkdir -p "${DATA_DIR}"

# Generate node-specific config from template by substituting
# placeholders with actual values.
sed \
  -e "s|__DATA_HOME__|${DATA_DIR}|g" \
  -e "s|__WAL_DIR__|${DATA_DIR}/wal|g" \
  -e "s|__LOG_DIR__|${DATA_DIR}/logs|g" \
  -e "s|__S3_BUCKET__|${S3_BUCKET}|g" \
  -e "s|__S3_ROOT__|data|g" \
  -e "s|__S3_ENDPOINT__|${S3_ENDPOINT_URL}|g" \
  -e "s|__S3_REGION__|${S3_REGION}|g" \
  -e "s|__S3_ACCESS_KEY__|${S3_ACCESS_KEY}|g" \
  -e "s|__S3_SECRET_KEY__|${S3_SECRET_KEY}|g" \
  "${CONFIG_TEMPLATE}" > "${CONFIG}"

exec ${GREPTIME_BIN} datanode start \
  --node-id "${NODE_ID}" \
  --grpc-bind-addr "${RPC_ADDR}" \
  --http-addr "${HTTP_ADDR}" \
  --metasrv-addrs "${METASRV_ADDR}" \
  --config-file "${CONFIG}"
