#!/usr/bin/env bash
set -euo pipefail

GREPTIME_BIN="${GREPTIME_BIN:-./greptime}"
GREPTIME_HOME="${GREPTIME_HOME:-./.greptimedb}"
DATA_DIR="${GREPTIME_HOME}/standalone"
CONFIG="${DATA_DIR}/standalone.toml"

. "${GREPTIME_HOME}/s3.env"

mkdir -p "${DATA_DIR}"

cat > "${CONFIG}" <<EOF
[http]
addr = "0.0.0.0:11070"

[grpc]
bind_addr = "0.0.0.0:11071"

[mysql]
addr = "0.0.0.0:11072"

[postgres]
addr = "0.0.0.0:11073"

[storage]
data_home = "${DATA_DIR}"
type = "S3"
bucket = "${S3_BUCKET}"
root = "standalone"
endpoint = "${S3_ENDPOINT_URL}"
region = "${S3_REGION}"
access_key_id = "${S3_ACCESS_KEY}"
secret_access_key = "${S3_SECRET_KEY}"

[wal]
provider = "raft_engine"
dir = "${DATA_DIR}/wal"

[logging]
dir = "${DATA_DIR}/logs"
EOF

exec ${GREPTIME_BIN} standalone start \
  --config-file "${CONFIG}"
